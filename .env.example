# Swap / Robinhood Chain (chainId 4663)
NEXT_PUBLIC_CHAIN_ID=4663
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_UNIVERSAL_ROUTER=0x53BF6B0684Ec7eF91e1387Da3D1a1769bC5A6F77
NEXT_PUBLIC_PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3
NEXT_PUBLIC_STATE_VIEW=0xf3334192d15450cdd385c8b70e03f9a6bd9e673b
# TODO: replace with the live HANSOME token list URL once deployed/hosted.
NEXT_PUBLIC_TOKEN_LIST=https://hansomealpacas.xyz/token-list/hansome-alpacas-robinhood.tokenlist.json

# Game / Genesis mint
# Current Production = Robinhood Testnet (46630). Mainnet cutover = 4663.
# See docs/MAINNET_VERCEL_CUTOVER.md — do not set 4663 until Mainnet contracts exist.
NEXT_PUBLIC_GAME_CHAIN_ID=46630
NEXT_PUBLIC_GAME_RPC_URL=https://rpc.testnet.chain.robinhood.com
NEXT_PUBLIC_GAME_EXPLORER=https://explorer.testnet.chain.robinhood.com
# Optional alias accepted by resolveGameExplorerUrl():
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://explorer.testnet.chain.robinhood.com
#
# Canonical Testnet suite (batched finalizeDay + creditBatch). REQUIRED — no silent
# fallbacks to superseded deployments. See contracts/deployments/robinhoodTestnet-game.json
# NEXT_PUBLIC_HANSOME_GAME_ADDRESS=0x92C8e9CCF67e533438bCCE258D4bEEc6E0559FC5
# NEXT_PUBLIC_REWARD_DISTRIBUTOR_ADDRESS=0x7Fb2437542041AbaC22E0A88dF2e0A9c3346e1d2
# NEXT_PUBLIC_HANSOME_GENESIS_ADDRESS=0x43c1d6aF194A796EC612F2bAC04085a409A1347C
# Alias still accepted for Genesis:
# NEXT_PUBLIC_GENESIS_NFT_ADDRESS=0x43c1d6aF194A796EC612F2bAC04085a409A1347C
# NEXT_PUBLIC_RANDOMNESS_ADDRESS=0x45F9FFaC891e06E83a5A315E4fE1B55E5b6b438F
# Testnet gasless resolve (default on when unset). Set 0/false to force wallet path.
# On Mainnet cutover set 0 until gasless Mainnet is explicitly approved.
# NEXT_PUBLIC_TESTNET_GASLESS_RESOLVE=1
# Test HANSOME (tHANSOME) — Robinhood Testnet ONLY. Not real $HANSOME.
# NEXT_PUBLIC_THANSOME_ADDRESS=
# Game day timings (seconds). Production GDS = 72000 / 14400 / 86400.
# Robinhood Testnet deploy defaults to fast QA: 120 / 120 / 240 (synced by sync-game-env).
# NEXT_PUBLIC_GAME_COMMIT_DURATION_SEC=120
# NEXT_PUBLIC_GAME_REVEAL_DURATION_SEC=120
# NEXT_PUBLIC_GAME_DAY_LENGTH_SEC=240
# --- Mainnet cutover (ONLY after robinhood-*.json exists) ---
# NEXT_PUBLIC_GAME_CHAIN_ID=4663
# NEXT_PUBLIC_GAME_RPC_URL=https://rpc.mainnet.chain.robinhood.com
# NEXT_PUBLIC_GAME_EXPLORER=https://robinhoodchain.blockscout.com
# NEXT_PUBLIC_GAME_COMMIT_DURATION_SEC=72000
# NEXT_PUBLIC_GAME_REVEAL_DURATION_SEC=14400
# NEXT_PUBLIC_GAME_DAY_LENGTH_SEC=86400
# Production reveal metadata (IPFS) — My NFTs artwork when chain URI is still placeholder
# NEXT_PUBLIC_GENESIS_METADATA_CID=bafybeihs7d6nzeq2s6woads3bsbpwa5g4fgspz7fmtxr4wd6xh2idd224e
# NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
# Genesis NFT Reveal timing (NOT gameplay Reveal Move):
# Default: immediate on Robinhood Testnet (46630), production schedule on Mainnet.
# Override: 1 = force immediate, 0 = force production wait.
# NEXT_PUBLIC_GENESIS_IMMEDIATE_NFT_REVEAL=

# Market stats (optional ETH/USD fallback when CoinGecko is unavailable)
NEXT_PUBLIC_ETH_USD=

# Community stats (optional — show "Coming Soon" when empty)
NEXT_PUBLIC_HOLDERS=
NEXT_PUBLIC_TRANSACTIONS=
NEXT_PUBLIC_LIQUIDITY=
NEXT_PUBLIC_MARKET_CAP=

# Analytics (optional — disabled when empty)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_DEBUG=

# ---------------------------------------------------------------------------
# Server-only secrets (Next.js API / Node scripts) — NEVER use NEXT_PUBLIC_*
# Keep these in .env.local / Vercel encrypted env. Never commit real values.
# ---------------------------------------------------------------------------
# Testnet gasless resolve relayer (revealBatch / seed / finalize / creditBatch).
# REQUIRED for gasless resolve — no fallback to DEPLOYER/TREASURY/PRIVATE_KEY.
# Use a dedicated hot wallet with minimal Testnet ETH. Do not reuse treasury,
# founder, owner, or Mainnet-funded keys. sync-game-env never copies this value.
# GAME_TESTNET_RELAYER_PRIVATE_KEY=
#
# Durable encrypted commit-salt vault (Vercel KV / Upstash Redis). REQUIRED for
# gasless Commit/Reveal. Filesystem storage is not supported.
# 32-byte key as 64 hex chars (or standard base64 of 32 bytes):
# GAME_TESTNET_COMMIT_VAULT_KEY=
# Vercel KV (preferred) — also accepts UPSTASH_REDIS_REST_URL / _TOKEN:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Local/dev only (never Production): allow in-memory vault without Redis:
# GAME_TESTNET_COMMIT_VAULT_DRIVER=memory
# GAME_TESTNET_COMMIT_VAULT_ALLOW_MEMORY=1
#
# Mainnet gasless / vault (chain 4663 only). NEVER copy Testnet keys here.
# Manual Vercel entry only — see docs/MAINNET_VERCEL_CUTOVER.md
# GAME_MAINNET_RELAYER_PRIVATE_KEY=
# GAME_MAINNET_COMMIT_VAULT_KEY=
#
# Optional dedicated game RPC (falls back to NEXT_PUBLIC_GAME_RPC_URL):
# GAME_RPC_URL=
# Pinata JWT for NFT IPFS publish scripts (scripts-nft / contracts tooling):
# PINATA_JWT=
