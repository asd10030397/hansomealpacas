# NEXT_PUBLIC_HANSOME_GENESIS_ADDRESS=0x43c1d6aF194A796EC612F2bAC04085a409A1347C
# NEXT_PUBLIC_RANDOMNESS_ADDRESS=0x45F9FFaC891e06E83a5A315E4fE1B55E5b6b438F
# NEXT_PUBLIC_GAME_COMMIT_DURATION_SEC=120
# NEXT_PUBLIC_GAME_REVEAL_DURATION_SEC=120
# NEXT_PUBLIC_GAME_DAY_LENGTH_SEC=240
# NEXT_PUBLIC_TESTNET_GASLESS_RESOLVE=1
# NEXT_PUBLIC_TESTNET_GAMEPLAY_TRAITS=1
# Testnet full NFT reveal (side/class/art/traits) while collectionRevealed=false on-chain:
# NEXT_PUBLIC_GENESIS_IMMEDIATE_NFT_REVEAL=1
# Public Testnet metadata root (contracts/deployments/robinhoodTestnet-genesis.json metadataCid)
# NEXT_PUBLIC_GENESIS_METADATA_CID=bafybeihs7d6nzeq2s6woads3bsbpwa5g4fgspz7fmtxr4wd6xh2idd224e
# NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
#
# Mainnet (4663) Production — blind-box until collection reveal:
# Do NOT set NEXT_PUBLIC_GENESIS_METADATA_CID pre-reveal (leaks rotation metadata into bundles).
# NEXT_PUBLIC_GENESIS_IMMEDIATE_NFT_REVEAL=0

# Market stats (optional ETH/USD fallback when CoinGecko is unavailable)
NEXT_PUBLIC_ETH_USD=

# Community stats (optional — show "Coming Soon" when empty)
NEXT_PUBLIC_HOLDERS=
NEXT_PUBLIC_TRANSACTIONS=
NEXT_PUBLIC_LIQUIDITY=
NEXT_PUBLIC_MARKET_CAP=

# Analytics (optional — disabled when empty)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GA_DEBUG=

# WalletConnect v2 / Reown (public project id — register at https://dashboard.reown.com)
# Required for Capacitor APK WebView wallet connect; desktop injected wallets still work without it.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ---------------------------------------------------------------------------
# Server-only secrets (Next.js API / Node scripts) — NEVER use NEXT_PUBLIC_*
# Keep these in .env.local / Vercel encrypted env. Never commit real values.
# ---------------------------------------------------------------------------
# Testnet gasless resolve relayer (revealBatch / seed / finalize / creditBatch).
# REQUIRED for gasless resolve — no fallback to DEPLOYER/TREASURY/PRIVATE_KEY.
# Use a dedicated hot wallet with minimal Testnet ETH. Do not reuse treasury,
# founder, owner, or Mainnet-funded keys. sync-game-env never copies this value.
# GAME_TESTNET_RELAYER_PRIVATE_KEY=
#
# Durable encrypted commit-salt vault (Vercel KV / Upstash Redis). REQUIRED for
# gasless Commit/Reveal. Filesystem storage is not supported.
# 32-byte key as 64 hex chars (or standard base64 of 32 bytes):
# GAME_TESTNET_COMMIT_VAULT_KEY=
# Vercel KV (preferred) — also accepts UPSTASH_REDIS_REST_URL / _TOKEN:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Local/dev only (never Production): allow in-memory vault without Redis:
# GAME_TESTNET_COMMIT_VAULT_DRIVER=memory
# GAME_TESTNET_COMMIT_VAULT_ALLOW_MEMORY=1
#
# Mainnet gasless / vault (chain 4663 only). NEVER copy Testnet keys here.
# Manual Vercel entry only — see docs/MAINNET_VERCEL_CUTOVER.md
# GAME_MAINNET_RELAYER_PRIVATE_KEY=
# GAME_MAINNET_COMMIT_VAULT_KEY=
#
# Optional dedicated game RPC (falls back to NEXT_PUBLIC_GAME_RPC_URL):
# GAME_RPC_URL=
# Pinata JWT for NFT IPFS publish scripts (scripts-nft / contracts tooling):
# PINATA_JWT=
#
# NFT Forum persistence (Production: Vercel KV — auto-injected when KV is linked):
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Local dev without KV falls back to data/forum/store.json automatically.
