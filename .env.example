NEXT_PUBLIC_WEBSITE=https://hansomealpacas.xyz
NEXT_PUBLIC_X=https://x.com/HansomeAlpacas
NEXT_PUBLIC_TELEGRAM=https://t.me/HandsomeAlpacasCommunity
NEXT_PUBLIC_CONTRACT=0x2C38Df5F59b04C3F3BB8c9E6C445E211eB1b0875
NEXT_PUBLIC_BUY=/swap
# Not set — no Uniswap v4 pool / chart exists yet.
NEXT_PUBLIC_CHART=
NEXT_PUBLIC_EXPLORER=https://robinhoodchain.blockscout.com
