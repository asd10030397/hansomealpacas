# Game / Genesis mint — Production cutover targets Robinhood Mainnet (4663).
# See docs/MAINNET_VERCEL_CUTOVER.md and contracts/deployments/robinhood-*.json
NEXT_PUBLIC_GAME_CHAIN_ID=4663
NEXT_PUBLIC_GAME_REQUIRE_MAINNET=1
NEXT_PUBLIC_GAME_RPC_URL=https://rpc.mainnet.chain.robinhood.com
NEXT_PUBLIC_GAME_EXPLORER=https://robinhoodchain.blockscout.com
# Optional alias accepted by resolveGameExplorerUrl():
# NEXT_PUBLIC_BLOCK_EXPLORER_URL=https://robinhoodchain.blockscout.com
#
# Canonical Mainnet suite (B7 ceremony). REQUIRED — no silent fallbacks.
NEXT_PUBLIC_HANSOME_GAME_ADDRESS=0xb8dad421881171f4485523d109C94dc650ecB7Eb
NEXT_PUBLIC_REWARD_DISTRIBUTOR_ADDRESS=0x0f9683287F91698B84Da4A3A90366a75EaF93520
NEXT_PUBLIC_HANSOME_GENESIS_ADDRESS=0x6eBb78FDB40CF6f6b8B33a235eF321AD15107cb0
# Alias still accepted for Genesis:
# NEXT_PUBLIC_GENESIS_NFT_ADDRESS=0x6eBb78FDB40CF6f6b8B33a235eF321AD15107cb0
NEXT_PUBLIC_RANDOMNESS_ADDRESS=0x134f3CE4006a04C2C5DaD0E654d1C4228dd15791
# GDS Production timings (seconds)
NEXT_PUBLIC_GAME_COMMIT_DURATION_SEC=72000
NEXT_PUBLIC_GAME_REVEAL_DURATION_SEC=14400
NEXT_PUBLIC_GAME_DAY_LENGTH_SEC=86400
# Gasless / Testnet trait deck OFF on Mainnet until explicitly approved.
NEXT_PUBLIC_TESTNET_GASLESS_RESOLVE=0
NEXT_PUBLIC_TESTNET_GAMEPLAY_TRAITS=0
# tHANSOME is Testnet-only — do not set on Mainnet Production.
# NEXT_PUBLIC_THANSOME_ADDRESS=
