# Contract deploy / Hardhat signer. Prefer a dedicated deployer.
# Never used by Next.js gasless resolve (that requires GAME_TESTNET_RELAYER_PRIVATE_KEY
# in repo-root .env.local / Vercel only — sync-game-env will not copy these keys).
DEPLOYER_PRIVATE_KEY=

# Token / LP treasury ops (create-v4-pool, liquidity scripts). Must NOT be the
# same key as the Testnet gasless relayer. Hardhat deploy scripts may fall back
# to this when DEPLOYER is unset — that is contracts-tooling convenience only
# and must never feed the Next.js relayer.
TREASURY_PRIVATE_KEY=

# Legacy alias accepted by hardhat.config / signer helpers. Prefer DEPLOYER_PRIVATE_KEY.
# PRIVATE_KEY=

# --- market-buy-external.ts ---
# A genuinely independent personal/external wallet's private key — NEVER the
# project Treasury. Used only for an "organic" market buy that should be
# indistinguishable on-chain from any other user's swap. There is NO fallback
# to PRIVATE_KEY/TREASURY_PRIVATE_KEY for this var by design (see
# getExternalBuyerSigner in scripts/lib/signer.ts) — it must be set explicitly
# with a real personal key, or the script refuses to run.
# Keep this in your local, gitignored .env only — never commit it, never
# paste it into chat/logs, and prefer a wallet dedicated solely to this
# purpose so a leaked key can't touch anything else.
EXTERNAL_BUYER_PRIVATE_KEY=

# --- Official Liquidity Wallet ops (ops-batched-market-buy.ts / mint-v4-liquidity.ts) ---
# Private key for 0x0bd54aeE53E9603375C27940d74e7c0923573b2a only.
# See .env.liquidity-ops.example. Never commit, never paste into chat.
# LIQUIDITY_PRIVATE_KEY=
# LIQUIDITY_EXPECTED_ADDRESS=0x0bd54aeE53E9603375C27940d74e7c0923573b2a
# BUY_BATCHES=0.25,0.30,0.35,0.40,0.40
# BATCH_DELAY_MS=180000

HANSOME_ALPACAS_ADDRESS=

# --- Test HANSOME (tHANSOME) — Robinhood Testnet ONLY ---
# Do not set / deploy on Mainnet. Not the real $HANSOME token.
# THANSOME_ADDRESS=
# GAME_TOKEN_ADDRESS=   # set to tHANSOME when deploying testnet game suite

ROBINHOOD_RPC_URL=
RH_RPC_URL=
RH_TESTNET_RPC_URL=

# --- deploy-genesis.ts (HansomeGenesisNFT) ---
# USE_REVEAL_MOCK=1 is auto-enabled on robinhoodTestnet.
# Testnet uses a 60s admin timelock by default (mainnet: omit / 0 = 24h).
USE_REVEAL_MOCK=1
SHORT_ADMIN_TIMELOCK=1
# ADMIN_TIMELOCK_SECONDS=60
# BOOTSTRAP_SALE=0
# GENESIS_MINT_PRICE_ETH=0.001
# ROYALTY_RECEIVER=
# PLACEHOLDER_URI=ipfs://hansome-genesis/placeholder.json
# RESERVE_MINT_TO=
# VRF_OPERATOR=

# --- Uniswap v4 pool scripts (create-v4-pool.ts / remove-v4-liquidity.ts) ---
# Nothing about the pool is hardcoded — set these explicitly before running
# create-v4-pool.ts. There are no defaults for deposit amounts.
POOL_FEE=500
POOL_TICK_SPACING=10
POOL_TICK_RANGE_MULTIPLIER=750
POOL_ETH_AMOUNT=
POOL_HANSOME_AMOUNT=

# --- remove-v4-liquidity.ts / query-position.ts / simulate-burn.ts / add-v4-liquidity.ts ---
POSITION_ID=
POSITION_OWNER=
AMOUNT0_MIN_WEI=
AMOUNT1_MIN_WEI=

# --- add-v4-liquidity.ts (increase liquidity on the existing Position NFT above) ---
# No defaults — the script refuses to run without these set explicitly.
ADD_ETH_AMOUNT=
ADD_HANSOME_AMOUNT=

# --- mint-v4-liquidity.ts (mint a brand-new Position NFT on the existing pool) ---
# Use this to add a *second* position at a different tick range — e.g. when
# the original position is locked (TitanLockerManagerV2) and can no longer
# be increased via add-v4-liquidity.ts. No defaults set intentionally.
MINT_TICK_LOWER=
MINT_TICK_UPPER=
MINT_ETH_AMOUNT=
MINT_HANSOME_AMOUNT=

# --- buy-hansome-for-lp.ts (step 1 of "deploy 100% of an ETH budget into a
# new LP position without touching any other wallet") ---
# Buys just enough extra HANSOME (with part of TOTAL_ETH_BUDGET) so that
# existing Treasury HANSOME + bought HANSOME exactly pairs with the *rest*
# of the ETH budget for the target range — prints the exact MINT_ETH_AMOUNT /
# MINT_HANSOME_AMOUNT to feed into mint-v4-liquidity.ts afterward.
TARGET_TICK_LOWER=
TARGET_TICK_UPPER=
TOTAL_ETH_BUDGET=
MAX_SLIPPAGE_BPS=100

# --- market-buy-external.ts (plain ETH -> HANSOME buy from the external
# wallet above — no LP pairing math, just a normal market swap) ---
BUY_ETH_AMOUNT=

# --- verify-v4-swaps.ts / check-uniswap-ui-discovery.ts / diagnose-v4-pool.ts (optional) ---
TEST_ETH_AMOUNT=
TEST_HANSOME_AMOUNT=
POOL_ID=
TX_HASH=
UNISWAP_API_KEY=
