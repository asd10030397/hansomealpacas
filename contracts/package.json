{
  "name": "ugly-deer-token",
  "version": "1.0.0",
  "private": true,
  "description": "UGLY DEER ($UGLY) fixed-supply ERC-20 for Robinhood Chain",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "deploy:robinhood-testnet": "hardhat run scripts/deploy.ts --network robinhoodTestnet",
    "deploy:robinhood": "hardhat run scripts/deploy.ts --network robinhood",
    "create-v4-pool:robinhood": "hardhat run scripts/create-v4-pool.ts --network robinhood",
    "remove-v4-liquidity:robinhood": "hardhat run scripts/remove-v4-liquidity.ts --network robinhood",
    "query-position:robinhood": "hardhat run scripts/query-position-39500.ts --network robinhood",
    "verify:robinhood-testnet": "hardhat run scripts/verify.ts --network robinhoodTestnet",
    "verify:robinhood": "hardhat run scripts/verify.ts --network robinhood",
    "typecheck": "tsc --noEmit",
    "validate:env": "hardhat run scripts/validate-env.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@uniswap/sdk-core": "^7.18.0",
    "@uniswap/v3-sdk": "^3.31.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "jsbi": "^4.3.2",
    "typescript": "^5.7.3"
  }
}
