{
  "name": "hansome-alpacas-token",
  "version": "1.0.0",
  "private": true,
  "description": "HANSOME ALPACAS ($HANSOME) fixed-supply ERC-20 for Robinhood Chain",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:genesis": "hardhat test test/HansomeGenesisNFT.test.ts",
    "test:game": "hardhat test test/game/SettlementLib.unit.ts test/game/HansomeGame.integration.ts",
    "deploy:genesis": "hardhat run scripts/deploy-genesis.ts",
    "deploy:game": "hardhat run scripts/deploy-game.ts",
    "deploy:thansome": "hardhat run scripts/deploy-thansome.ts",
    "fund:thansome-distributor": "hardhat run scripts/fund-test-reward-distributor.ts",
    "sync:game-env": "hardhat run scripts/sync-game-env.ts",
    "validate:game-flow": "hardhat run scripts/validate-game-flow.ts",
    "test:thansome": "hardhat test test/TestHANSOME.test.ts",
    "clean": "hardhat clean",
    "deploy:robinhood-testnet": "hardhat run scripts/deploy.ts --network robinhoodTestnet",
    "deploy:robinhood": "hardhat run scripts/deploy.ts --network robinhood",
    "create-v4-pool:robinhood": "hardhat run scripts/create-v4-pool.ts --network robinhood",
    "remove-v4-liquidity:robinhood": "hardhat run scripts/remove-v4-liquidity.ts --network robinhood",
    "add-v4-liquidity:robinhood": "hardhat run scripts/add-v4-liquidity.ts --network robinhood",
    "query-position:robinhood": "hardhat run scripts/query-position.ts --network robinhood",
    "simulate-burn:robinhood": "hardhat run scripts/simulate-burn.ts --network robinhood",
    "verify:robinhood-testnet": "hardhat run scripts/verify.ts --network robinhoodTestnet",
    "verify:robinhood": "hardhat run scripts/verify.ts --network robinhood",
    "typecheck": "tsc --noEmit",
    "validate:env": "hardhat run scripts/validate-env.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.2.0",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@uniswap/sdk-core": "^7.18.0",
    "@uniswap/v3-sdk": "^3.31.0",
    "dotenv": "^16.4.7",
    "hardhat": "^2.22.17",
    "jsbi": "^4.3.2",
    "typescript": "^5.7.3"
  }
}
