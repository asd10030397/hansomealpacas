{
  "name": "hansome-buy-bot",
  "version": "1.0.0",
  "private": true,
  "description": "Standalone Telegram buy/sell notification bot for HANSOME ALPACAS ($HANSOME) on Robinhood Chain, driven directly by Uniswap v4 PoolManager Swap events.",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  }
}
