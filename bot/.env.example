# =========================================================
# HANSOME ALPACAS — Telegram Buy/Sell Bot configuration
# Copy this file to .env and fill in the values below.
# =========================================================

# --- Telegram (required) ---------------------------------
# Production runs on Railway, independent of any developer's machine.
# Locally (npm start / npm run dev), always use a SEPARATE test bot +
# test group here — never the production BOT_TOKEN/CHAT_ID. Telegram only
# allows one active getUpdates consumer per bot token, so running a local
# instance with the same token as the live Railway deployment causes
# command conflicts and, since each keeps its own SQLite database, can
# send duplicate buy/sell notifications into the real community chat.
# See bot/README.md "Deployment model" for details.
#
# Create a bot with @BotFather to get a token.
BOT_TOKEN=

# The chat/channel/group the bot should post buy/sell alerts to.
# For a public channel you can use its @username (e.g. @HansomeAlpacas).
# For a group/private channel, use the numeric chat id (often negative,
# e.g. -1001234567890) — get it by adding the bot as admin and checking
# an update via https://api.telegram.org/bot<token>/getUpdates.
CHAT_ID=

# Only needed if CHAT_ID is a forum supergroup (Topics enabled) AND you
# want buy/sell alerts posted into a specific topic rather than "General".
# Sending without this still succeeds (Telegram returns ok:true) but lands
# in the General topic, which is easy to miss if your community mainly
# watches a different, named topic. To find the id: open the target topic
# in Telegram > "..." menu > Copy Link — the link looks like
# https://t.me/c/<id>/<thread_id>; use the trailing number here.
MESSAGE_THREAD_ID=

# --- Robinhood Chain RPC ----------------------------------
# Defaults to the same public RPC the website uses. Robinhood Chain's free
# public RPC does not support standard eth_subscribe WebSocket log
# subscriptions (only a low-level sequencer feed) — so this bot polls over
# HTTP by default. See README "Future Expansion" for WSS via a paid
# provider (Alchemy/QuickNode/Validation Cloud).
RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663

# --- Polling behavior --------------------------------------
# How often (ms) to poll for new Swap logs.
POLL_INTERVAL_MS=15000
# Max blocks per getLogs call (keeps requests within public RPC limits).
MAX_BLOCK_RANGE=2000
# On first boot (empty database), how many blocks to look back.
INITIAL_LOOKBACK_BLOCKS=500
# Cap for exponential backoff after repeated RPC failures.
MAX_BACKOFF_MS=120000
# Per-request RPC timeout (ms). ethers' own default is 300000ms (5 min),
# which is far too long to detect a stalled RPC call quickly — a hung
# request would otherwise sit silently with no error and no retry.
RPC_TIMEOUT_MS=20000
# One-time historical backfill window (hours), run automatically on first
# startup so 24H Volume / Largest Buy / Largest Sell / Total Buys / Total
# Sells are correct immediately instead of only reflecting trades seen
# after the bot happened to start. Runs exactly once (tracked in the
# database) — no Telegram notifications are sent for backfilled trades.
BACKFILL_HOURS=24

# --- Token / pool identifiers -------------------------------
# Defaults below mirror lib/chain.ts on the website — only override if the
# HANSOME contract, pool, or infra addresses ever change.
TOKEN_ADDRESS=0x2C38Df5F59b04C3F3BB8c9E6C445E211eB1b0875
POOL_ID=0x1165db4c55ea3c2c4881453937164906923c7c37a575286c1db81f19ead81a0d
POOL_MANAGER_ADDRESS=0x8366a39CC670B4001A1121B8F6A443A643e40951
STATE_VIEW_ADDRESS=0xf3334192d15450cdd385c8b70e03f9a6bd9e673b
TOKEN_DECIMALS=18
TOTAL_SUPPLY=1000000000
EXPLORER_BASE_URL=https://robinhoodchain.blockscout.com

# --- Links shown in notifications/commands ------------------
WEBSITE_URL=https://hansomealpacas.xyz
DEXSCREENER_URL=https://dexscreener.com/robinhood/0x1165db4c55ea3c2c4881453937164906923c7c37a575286c1db81f19ead81a0d

# --- Market data ---------------------------------------------
# Fallback ETH/USD price if CoinGecko is temporarily unavailable and no
# cached value exists yet. Leave empty to use the built-in default (3000).
ETH_USD_FALLBACK=
MARKET_CACHE_TTL_MS=25000

# --- Database --------------------------------------------------
# Relative (to bot/) or absolute path to the SQLite file. The folder is
# created automatically if it doesn't exist.
DATABASE_PATH=./data/hansome-bot.sqlite

# --- Logging -----------------------------------------------------
# debug | info | warn | error
# - info (default, recommended for production): startup, real buy/sell
#   events, warnings, and errors only.
# - debug: also logs full per-tick tracing (current block, last_processed_block,
#   every eth_getLogs call and result count, every decoded swap and its
#   buy/sell classification, and the exact reason any notification was
#   skipped). Verbose — use while diagnosing an issue, not for normal
#   long-term production logging.
LOG_LEVEL=info
